#version 450
#extension GL_EXT_mesh_shader : require

#include "font.glsli"

layout (location = 0) out vec3 uvlayer[];

layout(local_size_x = 32, local_size_y = 1, local_size_z = 1) in;
layout(triangles, max_vertices = 4, max_primitives = 2) out;

void main()
{
    uint charIndex = gl_GlobalInvocationID.x;
    uint numCharacters = heapInputData[pushData.inputDataBufferIndex].data.numCharacters;

    if (charIndex >= numCharacters) {
        SetMeshOutputsEXT(0, 0);
        return;
    }

    uint vertexCount = 4;
    uint triangleCount = 2;
    SetMeshOutputsEXT(vertexCount, triangleCount);  

    CharData ch = heapInputData[pushData.inputDataBufferIndex].data.characters[charIndex];
    vec2 quadSize = heapInputData[pushData.inputDataBufferIndex].data.quadSize;

    for (uint i = 0; i < 4; ++i) {
        vec2 uv = vec2(i % 2, i / 2);
        gl_MeshVerticesEXT[i].gl_Position = vec4(ch.coordinates + uv * quadSize, 0, 1);
        uvlayer[0] = vec3(uv, ch.layer);
    }

    gl_PrimitiveTriangleIndicesEXT[0] =  uvec3(0, 1, 2);
    gl_PrimitiveTriangleIndicesEXT[1] =  uvec3(2, 1, 3);
}